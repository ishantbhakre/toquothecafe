<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TOQUO – Asian Restaurant | Nagpur</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400;700&family=Cinzel:wght@400;600;900&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&display=swap" rel="stylesheet">
    <style>
        :root {
            --red:       #c0392b;
            --crimson:   #8b0000;
            --gold:      #d4af37;
            --gold-light:#f5e08b;
            --dark:      #0d0a08;
            --dark2:     #13100d;
            --ink:       #1a1209;
            --paper:     #f2ead8;
            --warm:      rgba(212,175,55,0.08);
            --glass:     rgba(255,255,255,0.04);
        }

        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        html { scroll-behavior: smooth; }

        body {
            background: var(--dark);
            color: var(--paper);
            font-family: 'Cormorant Garamond', serif;
            overflow-x: hidden;
            cursor: none;
        }

        /* ── CUSTOM CURSOR ── */
        .cursor {
            width: 12px; height: 12px;
            background: var(--gold);
            border-radius: 50%;
            position: fixed; top: 0; left: 0;
            pointer-events: none; z-index: 9999;
            transform: translate(-50%,-50%);
            transition: transform .1s ease, background .2s;
            mix-blend-mode: difference;
        }
        .cursor-ring {
            width: 36px; height: 36px;
            border: 1px solid var(--gold);
            border-radius: 50%;
            position: fixed; top: 0; left: 0;
            pointer-events: none; z-index: 9998;
            transform: translate(-50%,-50%);
            transition: transform .25s ease, opacity .2s;
            opacity: 0.5;
        }

        /* ── NOISE OVERLAY ── */
        body::before {
            content: '';
            position: fixed; inset: 0;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
            pointer-events: none; z-index: 0; opacity: .4;
        }

        /* ── NAV ── */
        nav {
            position: fixed; top: 0; width: 100%; z-index: 100;
            padding: 20px 60px;
            display: flex; align-items: center; justify-content: space-between;
            background: linear-gradient(180deg, rgba(13,10,8,.95) 0%, transparent 100%);
            backdrop-filter: blur(4px);
            border-bottom: 1px solid rgba(212,175,55,0.12);
        }
        .nav-logo {
            font-family: 'Cinzel', serif;
            font-size: 1.8rem; font-weight: 900;
            color: var(--gold);
            letter-spacing: 8px;
            text-decoration: none;
            text-shadow: 0 0 40px rgba(212,175,55,0.4);
        }
        .nav-links { display: flex; gap: 36px; list-style: none; }
        .nav-links a {
            color: rgba(242,234,216,0.7);
            text-decoration: none;
            font-family: 'Cormorant Garamond', serif;
            font-size: 0.9rem; letter-spacing: 3px;
            text-transform: uppercase;
            transition: color .3s, text-shadow .3s;
        }
        .nav-links a:hover { color: var(--gold); text-shadow: 0 0 12px rgba(212,175,55,0.5); }
        .nav-cta {
            padding: 10px 24px;
            border: 1px solid var(--gold);
            color: var(--gold) !important;
            border-radius: 2px;
            transition: background .3s, color .3s !important;
        }
        .nav-cta:hover { background: var(--gold); color: var(--dark) !important; }

        /* ── HERO ── */
        #hero {
            position: relative; height: 100vh;
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            overflow: hidden;
        }
        .hero-bg {
            position: absolute; inset: 0;
            background:
                radial-gradient(ellipse 80% 60% at 50% 40%, rgba(139,0,0,0.18) 0%, transparent 70%),
                radial-gradient(ellipse 40% 40% at 20% 80%, rgba(212,175,55,0.08) 0%, transparent 60%),
                linear-gradient(160deg, #0d0a08 0%, #13100d 50%, #1a0a06 100%);
            z-index: 0;
        }

        /* 3D floating lanterns */
        .lantern-wrap {
            position: absolute; inset: 0; z-index: 1;
            perspective: 800px;
            pointer-events: none;
        }
        .lantern {
            position: absolute;
            animation: floatLantern 8s ease-in-out infinite;
        }
        .lantern svg { filter: drop-shadow(0 0 18px rgba(192,57,43,0.7)); }
        .l1 { top: 8%; left: 10%; animation-delay: 0s; }
        .l2 { top: 12%; right: 12%; animation-delay: -2s; }
        .l3 { top: 30%; left: 5%; animation-delay: -4s; transform: scale(0.7); }
        .l4 { top: 20%; right: 6%; animation-delay: -6s; transform: scale(0.65); }
        .l5 { top: 5%; left: 40%; animation-delay: -1s; transform: scale(0.55); }

        @keyframes floatLantern {
            0%,100% { transform: translateY(0) rotate(-3deg); }
            50%      { transform: translateY(-22px) rotate(3deg); }
        }

        /* Japanese kanji decoration */
        .kanji-bg {
            position: absolute; inset: 0; z-index: 1;
            font-family: 'Noto Serif JP', serif;
            font-size: 20vw; font-weight: 700;
            color: rgba(192,57,43,0.04);
            display: flex; align-items: center; justify-content: center;
            user-select: none; pointer-events: none;
            letter-spacing: -0.05em;
        }

        .hero-content { position: relative; z-index: 2; text-align: center; }
        .hero-eyebrow {
            font-family: 'Noto Serif JP', serif;
            font-size: 0.85rem; letter-spacing: 8px;
            color: var(--gold); text-transform: uppercase;
            margin-bottom: 20px;
            animation: fadeUp .8s ease both;
        }
        .hero-title {
            font-family: 'Cinzel', serif;
            font-size: clamp(5rem, 14vw, 11rem);
            font-weight: 900; line-height: 0.9;
            letter-spacing: 0.12em;
            color: var(--paper);
            text-shadow:
                0 2px 0 rgba(212,175,55,0.3),
                0 8px 40px rgba(139,0,0,0.5),
                0 0 80px rgba(192,57,43,0.2);
            animation: fadeUp .9s .1s ease both;
        }
        .hero-title span { color: var(--gold); }
        .hero-tagline {
            margin-top: 16px;
            font-size: 1.3rem; font-style: italic;
            color: rgba(242,234,216,0.55);
            letter-spacing: 2px;
            animation: fadeUp 1s .25s ease both;
        }
        .hero-rating {
            margin-top: 28px;
            display: flex; align-items: center; justify-content: center; gap: 10px;
            animation: fadeUp 1s .4s ease both;
        }
        .stars { color: var(--gold); font-size: 1.1rem; letter-spacing: 3px; }
        .rating-txt { font-size: 0.85rem; letter-spacing: 2px; color: rgba(242,234,216,0.5); }
        .hero-btns {
            margin-top: 40px; display: flex; gap: 20px; justify-content: center;
            animation: fadeUp 1s .5s ease both;
        }
        .btn-primary {
            padding: 16px 42px;
            background: linear-gradient(135deg, var(--crimson), var(--red));
            color: var(--paper); border: none;
            font-family: 'Cinzel', serif; font-size: 0.8rem; letter-spacing: 4px;
            text-transform: uppercase; cursor: pointer; border-radius: 2px;
            box-shadow: 0 8px 30px rgba(139,0,0,0.5);
            transition: all .3s ease; text-decoration: none; display: inline-block;
        }
        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 16px 40px rgba(139,0,0,0.6);
        }
        .btn-outline {
            padding: 16px 42px;
            border: 1px solid rgba(212,175,55,0.5);
            color: var(--gold);
            font-family: 'Cinzel', serif; font-size: 0.8rem; letter-spacing: 4px;
            text-transform: uppercase; cursor: pointer; border-radius: 2px;
            background: transparent;
            transition: all .3s; text-decoration: none; display: inline-block;
        }
        .btn-outline:hover { background: rgba(212,175,55,0.1); border-color: var(--gold); }

        .scroll-hint {
            position: absolute; bottom: 32px; left: 50%;
            transform: translateX(-50%);
            z-index: 2; display: flex; flex-direction: column; align-items: center; gap: 8px;
            animation: fadeUp 1s .8s ease both;
        }
        .scroll-hint span {
            font-size: 0.65rem; letter-spacing: 4px; color: rgba(242,234,216,0.3);
            text-transform: uppercase;
        }
        .scroll-line {
            width: 1px; height: 50px;
            background: linear-gradient(180deg, var(--gold), transparent);
            animation: scrollPulse 2s ease-in-out infinite;
        }
        @keyframes scrollPulse {
            0%,100% { opacity: 0; transform: scaleY(0.3) translateY(-10px); }
            50%      { opacity: 1; transform: scaleY(1)   translateY(0); }
        }

        /* ── SECTION SHARED ── */
        section { position: relative; }
        .section-label {
            font-family: 'Noto Serif JP', serif;
            font-size: 0.7rem; letter-spacing: 6px;
            color: var(--gold); text-transform: uppercase;
            margin-bottom: 12px;
        }
        .section-title {
            font-family: 'Cinzel', serif;
            font-size: clamp(2rem, 5vw, 3.5rem);
            line-height: 1.1; font-weight: 600;
            margin-bottom: 16px;
        }
        .section-divider {
            width: 60px; height: 1px;
            background: linear-gradient(90deg, var(--gold), transparent);
            margin-bottom: 24px;
        }

        /* ── ABOUT ── */
        #about {
            padding: 120px 60px;
            display: grid; grid-template-columns: 1fr 1fr; gap: 80px;
            align-items: center;
            background: linear-gradient(180deg, var(--dark) 0%, var(--dark2) 100%);
        }
        .about-visual {
            position: relative; height: 520px;
            perspective: 1000px;
        }
        .about-card {
            position: absolute; border-radius: 4px; overflow: hidden;
        }
        .about-card-main {
            width: 320px; height: 420px;
            top: 0; left: 0;
            background: linear-gradient(135deg, #3a0a0a, #1a0505);
            border: 1px solid rgba(192,57,43,0.3);
            transform: rotateY(-8deg) rotateX(4deg);
            transition: transform .5s ease;
            box-shadow: 20px 20px 60px rgba(0,0,0,0.6), -5px -5px 20px rgba(192,57,43,0.1);
            display: flex; flex-direction: column;
            justify-content: flex-end; padding: 30px;
        }
        .about-card-main::before {
            content: '東';
            position: absolute; top: 20px; right: 20px;
            font-family: 'Noto Serif JP', serif;
            font-size: 6rem; font-weight: 700;
            color: rgba(192,57,43,0.15);
        }
        .about-card-accent {
            width: 200px; height: 260px;
            top: 160px; left: 240px;
            background: linear-gradient(135deg, #1c1005, #0d0a08);
            border: 1px solid rgba(212,175,55,0.2);
            transform: rotateY(5deg) rotateX(-3deg);
            box-shadow: 15px 15px 40px rgba(0,0,0,0.5);
            display: flex; align-items: center; justify-content: center;
        }
        .about-card-accent-inner { text-align: center; }
        .about-card-accent-inner .num {
            font-family: 'Cinzel', serif; font-size: 3.5rem;
            color: var(--gold); line-height: 1;
        }
        .about-card-accent-inner .label {
            font-size: 0.7rem; letter-spacing: 3px;
            color: rgba(242,234,216,0.4); text-transform: uppercase;
        }
        .about-visual:hover .about-card-main { transform: rotateY(-4deg) rotateX(2deg); }
        .card-tag {
            font-family: 'Noto Serif JP', serif;
            font-size: 0.65rem; letter-spacing: 3px;
            color: var(--gold); margin-bottom: 8px;
        }
        .card-name {
            font-family: 'Cinzel', serif; font-size: 1.4rem;
            color: var(--paper);
        }
        .about-text p {
            font-size: 1.15rem; line-height: 1.9;
            color: rgba(242,234,216,0.65); margin-bottom: 20px;
        }
        .about-stats {
            display: grid; grid-template-columns: repeat(3,1fr); gap: 24px;
            margin-top: 40px; padding-top: 40px;
            border-top: 1px solid rgba(212,175,55,0.1);
        }
        .stat-item { text-align: center; }
        .stat-num {
            font-family: 'Cinzel', serif; font-size: 2.2rem;
            color: var(--gold); line-height: 1;
        }
        .stat-lbl {
            font-size: 0.7rem; letter-spacing: 3px;
            color: rgba(242,234,216,0.4); text-transform: uppercase;
            margin-top: 4px;
        }

        /* ── MENU ── */
        #menu {
            padding: 120px 60px;
            background: var(--dark2);
        }
        .menu-header { text-align: center; margin-bottom: 70px; }
        .menu-grid {
            display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 28px; max-width: 1200px; margin: 0 auto;
        }
        .menu-item {
            background: var(--glass);
            border: 1px solid rgba(212,175,55,0.1);
            border-radius: 4px; padding: 30px 28px;
            position: relative; overflow: hidden;
            transition: all .4s ease;
            transform-style: preserve-3d;
        }
        .menu-item::before {
            content: '';
            position: absolute; inset: 0;
            background: linear-gradient(135deg, rgba(139,0,0,0.05), transparent);
            opacity: 0; transition: opacity .4s;
        }
        .menu-item:hover {
            transform: translateY(-8px) rotateX(2deg);
            border-color: rgba(212,175,55,0.35);
            box-shadow: 0 20px 50px rgba(0,0,0,0.4), 0 0 30px rgba(212,175,55,0.06);
        }
        .menu-item:hover::before { opacity: 1; }
        .menu-emoji { font-size: 2.5rem; margin-bottom: 16px; }
        .menu-name {
            font-family: 'Cinzel', serif; font-size: 1.15rem;
            color: var(--paper); margin-bottom: 8px;
        }
        .menu-desc {
            font-size: 0.95rem; line-height: 1.7;
            color: rgba(242,234,216,0.45); margin-bottom: 20px;
        }
        .menu-price {
            font-family: 'Cinzel', serif;
            color: var(--gold); font-size: 1.1rem;
        }
        .menu-tag {
            position: absolute; top: 16px; right: 16px;
            background: rgba(192,57,43,0.15);
            border: 1px solid rgba(192,57,43,0.3);
            color: #e07070; font-size: 0.6rem;
            letter-spacing: 2px; padding: 4px 10px;
            text-transform: uppercase; border-radius: 2px;
        }

        /* ── EXPERIENCE / FEATURES ── */
        #experience {
            padding: 120px 60px;
            background: linear-gradient(135deg, #0d0a08, #160a06);
        }
        .exp-header { text-align: center; margin-bottom: 70px; }
        .exp-grid {
            display: grid; grid-template-columns: repeat(auto-fit, minmax(240px,1fr));
            gap: 24px; max-width: 1100px; margin: 0 auto;
        }
        .exp-card {
            padding: 36px 28px;
            border: 1px solid rgba(212,175,55,0.08);
            border-radius: 4px;
            background: linear-gradient(160deg, rgba(255,255,255,0.03) 0%, transparent 100%);
            text-align: center;
            transition: all .4s;
            transform-style: preserve-3d;
        }
        .exp-card:hover {
            transform: translateY(-6px) rotateY(4deg);
            border-color: rgba(212,175,55,0.25);
            box-shadow: 0 20px 50px rgba(0,0,0,0.3);
        }
        .exp-icon {
            width: 64px; height: 64px; margin: 0 auto 20px;
            background: rgba(212,175,55,0.08);
            border-radius: 50%; display: flex; align-items: center; justify-content: center;
            font-size: 1.8rem;
            border: 1px solid rgba(212,175,55,0.15);
        }
        .exp-title {
            font-family: 'Cinzel', serif; font-size: 1rem; letter-spacing: 2px;
            color: var(--paper); margin-bottom: 10px;
        }
        .exp-desc {
            font-size: 0.95rem; line-height: 1.7;
            color: rgba(242,234,216,0.4);
        }

        /* ── GALLERY ── */
        #gallery {
            padding: 120px 60px;
            background: var(--dark);
        }
        .gallery-header { text-align: center; margin-bottom: 60px; }
        .gallery-grid {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr;
            grid-template-rows: 220px 220px;
            gap: 12px; max-width: 1100px; margin: 0 auto;
        }
        .gallery-item {
            border-radius: 4px; overflow: hidden;
            position: relative;
            background: var(--dark2);
            border: 1px solid rgba(212,175,55,0.08);
            transition: all .4s;
            display: flex; align-items: center; justify-content: center;
        }
        .gallery-item:first-child { grid-row: span 2; }
        .gallery-item:hover { border-color: rgba(212,175,55,0.3); transform: scale(0.98); }
        .gallery-placeholder {
            font-family: 'Noto Serif JP', serif;
            font-size: 4rem; color: rgba(212,175,55,0.1);
        }
        .gallery-overlay {
            position: absolute; inset: 0;
            background: linear-gradient(135deg, rgba(139,0,0,0.6), rgba(13,10,8,0.4));
            opacity: 0; transition: opacity .4s;
            display: flex; align-items: center; justify-content: center;
        }
        .gallery-item:hover .gallery-overlay { opacity: 1; }
        .gallery-overlay-txt {
            font-family: 'Cinzel', serif; font-size: 0.8rem;
            letter-spacing: 4px; color: var(--paper); text-transform: uppercase;
        }

        /* ── RESERVATION ── */
        #reservation {
            padding: 120px 60px;
            background: linear-gradient(180deg, var(--dark2), var(--dark));
            display: flex; flex-direction: column; align-items: center;
        }
        .res-header { text-align: center; margin-bottom: 60px; }

        /* reservation card styles from user */
        .reservation-container {
            width: 100%; display: flex; justify-content: center;
        }
        .booking-card {
            background: rgba(255,255,255,0.04);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(212,175,55,0.2);
            padding: 50px 44px;
            border-radius: 8px;
            width: 100%; max-width: 480px;
            box-shadow: 0 30px 60px rgba(0,0,0,0.6);
            text-align: center;
            transition: transform .3s ease, box-shadow .3s ease;
        }
        .booking-card:hover {
            transform: translateY(-6px) rotateX(1deg);
            border-color: var(--gold);
            box-shadow: 0 40px 80px rgba(0,0,0,0.7), 0 0 40px rgba(212,175,55,0.08);
        }
        .booking-card h2 {
            font-family: 'Cinzel', serif;
            color: var(--gold); letter-spacing: 5px;
            margin-bottom: 32px; text-transform: uppercase; font-size: 1.8rem;
        }
        .input-group { position: relative; margin-bottom: 20px; text-align: left; }
        .input-group label {
            display: block; color: var(--gold);
            font-family: 'Cormorant Garamond', serif;
            font-size: 0.72rem; letter-spacing: 3px;
            text-transform: uppercase; margin-bottom: 6px;
        }
        .input-group input {
            width: 100%; padding: 14px 16px;
            background: rgba(0,0,0,0.35);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 4px; color: var(--paper);
            font-family: 'Cormorant Garamond', serif; font-size: 1rem;
            outline: none; transition: .3s;
        }
        .input-group input::placeholder { color: rgba(242,234,216,0.3); }
        .input-group input:focus {
            border-color: var(--gold);
            box-shadow: 0 0 12px rgba(212,175,55,0.2);
        }
        input[type="date"]::-webkit-calendar-picker-indicator,
        input[type="time"]::-webkit-calendar-picker-indicator {
            filter: invert(70%) sepia(50%) saturate(500%) hue-rotate(10deg);
            cursor: pointer;
        }
        .confirm-btn {
            width: 100%; padding: 16px;
            background: linear-gradient(135deg, #b8860b, #ffd700);
            border: none; border-radius: 4px;
            color: #0d0a08; font-family: 'Cinzel', serif;
            font-weight: 700; font-size: 0.8rem;
            letter-spacing: 4px; text-transform: uppercase;
            cursor: pointer; transition: all .3s ease; margin-top: 12px;
        }
        .confirm-btn:hover {
            letter-spacing: 6px;
            box-shadow: 0 0 24px rgba(212,175,55,0.4);
            transform: scale(1.02);
        }

        /* ── LOCATION ── */
        #location {
            padding: 120px 60px;
            background: var(--dark2);
        }
        .location-inner {
            max-width: 1100px; margin: 0 auto;
            display: grid; grid-template-columns: 1fr 1fr; gap: 60px;
            align-items: start;
        }
        .location-info {}
        .location-detail {
            display: flex; gap: 20px; align-items: flex-start;
            margin-bottom: 28px;
        }
        .location-icon {
            width: 44px; height: 44px; flex-shrink: 0;
            background: rgba(212,175,55,0.07);
            border: 1px solid rgba(212,175,55,0.15);
            border-radius: 50%; display: flex; align-items: center; justify-content: center;
            font-size: 1.1rem;
        }
        .location-txt-title {
            font-family: 'Cinzel', serif; font-size: 0.8rem;
            letter-spacing: 3px; color: var(--gold);
            text-transform: uppercase; margin-bottom: 4px;
        }
        .location-txt-val {
            font-size: 1rem; color: rgba(242,234,216,0.6); line-height: 1.6;
        }
        .map-container {
            border-radius: 8px; overflow: hidden;
            border: 1px solid rgba(212,175,55,0.15);
            box-shadow: 0 20px 60px rgba(0,0,0,0.5);
            height: 380px;
        }
        .map-container iframe { width: 100%; height: 100%; border: 0; display: block; }

        /* ── REVIEWS ── */
        #reviews {
            padding: 120px 60px;
            background: linear-gradient(180deg, var(--dark), var(--dark2));
        }
        .reviews-header { text-align: center; margin-bottom: 60px; }
        .reviews-grid {
            display: grid; grid-template-columns: repeat(auto-fit, minmax(280px,1fr));
            gap: 24px; max-width: 1100px; margin: 0 auto;
        }
        .review-card {
            padding: 32px 28px;
            background: var(--glass);
            border: 1px solid rgba(212,175,55,0.08);
            border-radius: 4px;
            transition: all .4s;
        }
        .review-card:hover {
            transform: translateY(-4px);
            border-color: rgba(212,175,55,0.25);
        }
        .review-stars { color: var(--gold); margin-bottom: 14px; font-size: 0.95rem; }
        .review-text {
